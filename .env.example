# Public site config
NEXT_PUBLIC_SITE_URL=https://studycapture.co
NEXT_PUBLIC_CONTACT_EMAIL=support@studycapture.co
NEXT_PUBLIC_SUPPORT_EMAIL=support@studycapture.co
NEXT_PUBLIC_BILLING_EMAIL=billing@studycapture.co
NEXT_PUBLIC_FOUNDER_EMAIL=founder@studycapture.co

# Supabase Auth. The anon key is public-safe; the service role key must stay server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server-only signing/rate-limit secrets. Use long random values in production.
LICENSE_TOKEN_SECRET=
DEVICE_HASH_SECRET=
RATE_LIMIT_SECRET=

# Comma-separated emails allowed to open /admin after OTP verification.
ADMIN_EMAILS=founder@studycapture.co

# Razorpay live payment flow. Never expose RAZORPAY_KEY_SECRET.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=
RAZORPAY_WEBHOOK_SECRET=

# Hidden founder-only live payment test mode. Keep disabled except during internal tests.
ENABLE_INTERNAL_TEST_PAYMENTS=false
FOUNDER_TEST_TOKEN=
TEST_PRICE_INR=1
PUBLIC_PRICE_INR=799

# Store install URLs
NEXT_PUBLIC_CHROME_STORE_URL=
NEXT_PUBLIC_EDGE_STORE_URL=
NEXT_PUBLIC_FIREFOX_STORE_URL=
NEXT_PUBLIC_SAFARI_STORE_URL=

# Optional CTA overrides. Defaults are /install and /upgrade.
NEXT_PUBLIC_INSTALL_URL=
NEXT_PUBLIC_PRO_URL=

# Resend-ready email delivery. Optional until payment webhooks are connected.
RESEND_API_KEY=
RESEND_FROM_EMAIL=Study Capture <billing@studycapture.co>
